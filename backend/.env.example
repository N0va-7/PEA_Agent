# ===== Storage =====
# Production recommended: use MySQL via DATABASE_URL.
# Dev compatible: leave DATABASE_URL empty and use SQLITE_DB_PATH.
# Optional. If set, it overrides SQLITE_DB_PATH. Examples:
# - sqlite: sqlite:////Users/qwx/dev/code/PEA_Agent/runtime/db/analysis.db
# - mysql:  mysql+pymysql://user:pass@127.0.0.1:3306/pea_agent?charset=utf8mb4
DATABASE_URL=""
SQLITE_DB_PATH="/Users/qwx/dev/code/PEA_Agent/runtime/db/analysis.db"
REPORT_OUTPUT_DIR="/Users/qwx/dev/code/PEA_Agent/runtime/reports"
UPLOAD_DIR="/Users/qwx/dev/code/PEA_Agent/runtime/uploads"
MODEL_DIR="/Users/qwx/dev/code/PEA_Agent/ml/artifacts"
UPLOAD_RETENTION_HOURS="72"

# ===== LLM =====
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL_ID="gpt-4o-mini"

# ===== Threat Intel =====
THREATBOOK_API_KEY=""

# ===== Auth / JWT =====
AUTH_USERNAME="admin"
# Support legacy SHA256 or stronger pbkdf2_sha256 format.
AUTH_PASSWORD_HASH=""
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
JWT_EXPIRE_HOURS="8"
LOGIN_RATE_MAX_ATTEMPTS="10"
LOGIN_RATE_WINDOW_SECONDS="300"
EXPOSE_INTERNAL_ERROR_DETAILS="false"

# ===== CORS =====
CORS_ALLOW_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:8501"

# ===== Fusion Tuning Gates =====
TUNING_MIN_TOTAL_SAMPLES="500"
TUNING_MIN_CLASS_SAMPLES="100"
TUNING_RECENT_DAYS="7"

# ===== Job Queue =====
# Production recommended: redis
# Dev compatible: memory
# memory | redis
JOB_QUEUE_BACKEND="memory"
REDIS_URL="redis://127.0.0.1:6379/0"
REDIS_QUEUE_NAME="pea:jobs"
