# ===== Storage =====
# Default development stack now uses MySQL + Redis directly.
# Start infra first: docker compose up -d mysql redis
DATABASE_URL="mysql+pymysql://root:root@127.0.0.1:3306/pea_agent?charset=utf8mb4"
SQLITE_DB_PATH="/Users/qwx/dev/code/PEA_Agent/runtime/db/analysis.db"
REPORT_OUTPUT_DIR="/Users/qwx/dev/code/PEA_Agent/runtime/reports"
UPLOAD_DIR="/Users/qwx/dev/code/PEA_Agent/runtime/uploads"
MODEL_DIR="/Users/qwx/dev/code/PEA_Agent/ml/artifacts"
UPLOAD_RETENTION_HOURS="72"

# ===== LLM =====
LLM_API_KEY=""
LLM_BASE_URL="https://api.openai.com/v1"
LLM_MODEL_ID="gpt-4o-mini"

# ===== Threat Intel =====
VT_API_KEY=""
VT_BASE_URL="https://www.virustotal.com/api/v3"
VT_ENABLED="true"
VT_PUBLIC_MODE="true"
VT_CACHE_TTL_HOURS="24"
VT_MIN_INTERVAL_SECONDS="15"
VT_DAILY_BUDGET="500"
VT_TIMEOUT_SECONDS="20"

# ===== Attachment Sandbox =====
ATTACHMENT_SANDBOX_BASE_URL="http://127.0.0.1:8000"
ATTACHMENT_SANDBOX_SOURCE_ID="pea-agent"
ATTACHMENT_SANDBOX_TIMEOUT_SECONDS="45"
ATTACHMENT_SANDBOX_POLL_INTERVAL_SECONDS="2"

# ===== Auth / JWT =====
AUTH_USERNAME="admin"
# Support legacy SHA256 or stronger pbkdf2_sha256 format.
AUTH_PASSWORD_HASH=""
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
JWT_EXPIRE_HOURS="8"
LOGIN_RATE_MAX_ATTEMPTS="10"
LOGIN_RATE_WINDOW_SECONDS="300"
EXPOSE_INTERNAL_ERROR_DETAILS="false"

# ===== CORS =====
CORS_ALLOW_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:8501"

# ===== Fusion Tuning Gates =====
TUNING_MIN_TOTAL_SAMPLES="500"
TUNING_MIN_CLASS_SAMPLES="100"
TUNING_RECENT_DAYS="7"

# ===== Job Queue =====
# memory | redis
JOB_QUEUE_BACKEND="redis"
REDIS_URL="redis://127.0.0.1:6379/0"
REDIS_QUEUE_NAME="pea:jobs"
